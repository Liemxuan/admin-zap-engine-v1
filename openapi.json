    "/api/product/list": {
      "post": {
        "tags": [
          "Product"
        ],
        "x-apidog-folder": "Product",
        "summary": "List products",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "page_index": {
                    "type": "integer",
                    "example": 1
                  },
                  "page_size": {
                    "type": "integer",
                    "example": 10
                  },
                  "search": {
                    "type": "string",
                    "example": "iphone"
                  },
                  "filters": {
                    "type": "object",
                    "properties": {
                      "cate_id": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        },
                        "example": [
                          "1",
                          "2"
                        ]
                      },
                      "status": {
                        "type": "array",
                        "items": {
                          "type": "integer"
                        },
                        "example": [
                          1,
                          2
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/SuccessListProduct"
          },
          "401": {
            "$ref": "#/components/responses/ErrorUnauthorized"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "ApiResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": ""
          },
          "data": {}
        }
      },
      "Product": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "cate_name": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "status": {
            "type": "integer"
          }
        }
      }
    },
    "responses": {
