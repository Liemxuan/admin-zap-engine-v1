                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/verify-otp": {
      "post": {
        "tags": [
          "Login"
        ],
        "x-apidog-folder": "Login",
        "summary": "3. Verify OTP & Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "account": {
                    "type": "string",
                    "example": "MER-12345"
                  },
                  "otp": {
                    "type": "string",
                    "example": "123456"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/SuccessLogin"
          },
          "400": {
            "$ref": "#/components/responses/ErrorInvalidOtp"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Login"
        ],
        "x-apidog-folder": "Login",
        "summary": "4. Login with password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "account": {
                    "type": "string",
                    "example": "MER-12345"
                  },
                  "password": {
                    "type": "string",
                    "example": "P@ssw0rd!"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "$ref": "#/components/responses/SuccessLogin"
          },
          "401": {
            "$ref": "#/components/responses/ErrorUnauthorized"
          }
        }
      }
    },
