{
  "openapi": "3.0.0",
  "info": {
    "title": "ZAP Design Engine API (v1.3.0)",
    "version": "1.3.0",
    "description": "Clean design: Grouped Login & Register folders"
  },
  "tags": [
    {
      "name": "Login",
      "description": "Folder: Login"
    },
    {
      "name": "Register",
      "description": "Folder: Register"
