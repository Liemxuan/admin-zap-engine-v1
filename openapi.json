  "paths": {
    "/api/auth/check-account": {
      "post": {
        "tags": [
          "Login"
        ],
        "x-apidog-folder": "Login",
        "summary": "1. Check account (Login)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "account": {
                    "type": "string",
                    "example": "MER-12345"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Account exists",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "properties": {
                        "code": {
                          "example": 200
                        },
                        "success": {
                          "example": true
                        },
                        "message": {
                          "example": "Account found"
                        },
                        "data": {
                          "type": "object",
                          "properties": {
                            "exists": {
                              "type": "boolean",
                              "example": true
                            },
                            "methods": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              },
                              "example": [
                                "password",
                                "otp"
                              ]
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Account not found",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/ApiResponse"
                    },
                    {
                      "properties": {
                        "code": {
                          "example": 404
                        },
                        "success": {
                          "example": false
                        },
                        "message": {
                          "example": "Account not found"
                        },
                        "data": {
                          "example": null
                        }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/send-otp": {
      "post": {
        "tags": [
          "Login"
        ],
        "x-apidog-folder": "Login",
        "summary": "2. Send OTP (Login)",
        "requestBody": {
          "required": true,
