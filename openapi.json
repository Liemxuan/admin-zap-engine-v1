        "description": "Login successful",
        "content": {
          "application/json": {
            "schema": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/ApiResponse"
                },
                {
                  "properties": {
                    "code": {
                      "example": 200
                    },
                    "success": {
                      "example": true
                    },
                    "message": {
                      "example": "Login successful"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": {
                          "type": "string"
                        },
                        "merchant_id": {
                          "type": "string"
                        },
                        "email": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        },
                        "logo_url": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      },
      "SuccessListProduct": {
        "description": "Product list retrieved",
        "content": {
          "application/json": {
            "schema": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/ApiResponse"
                },
                {
                  "properties": {
                    "code": {
                      "example": 200
                    },
                    "success": {
                      "example": true
                    },
                    "message": {
                      "example": "OK"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "total_page": {
                          "type": "integer",
                          "example": 100
                        },
                        "total_record": {
                          "type": "integer",
                          "example": 1000
                        },
                        "page_index": {
                          "type": "integer",
                          "example": 1
                        },
                        "page_size": {
                          "type": "integer",
                          "example": 10
                        },
                        "items": {
                          "type": "array",
                          "items": {
                            "$ref": "#/components/schemas/Product"
                          }
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        }
      },
      "ErrorBadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/ApiResponse"
                },
                {
                  "properties": {
                    "code": {
                      "example": 400
                    },
                    "success": {
                      "example": false
                    },
