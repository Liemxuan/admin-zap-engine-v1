# =================================================================
# SECURITY & SENSITIVE DATA (MOST IMPORTANT)
# Prevents reading files containing passwords, API keys, DB connection strings
# =================================================================
.env
.env.*
*.pem
*.key
*.cert
secrets.json
auth.json

# =================================================================
# TOKEN SAVINGS: LIBRARIES & DEPENDENCIES
# No need to read third-party library source code
# =================================================================
node_modules/
.npm/
.yarn/
vendor/

# =================================================================
# TOKEN SAVINGS: BUILD & COMPILE OUTPUT
# Prevents reading minified code or compiled binaries
# =================================================================
# React / Vite / Node.js
dist/
build/
out/
.vite/
.next/

# C# / .NET (if backend code shares the same repo)
bin/
obj/
TestResults/

# =================================================================
# TOKEN SAVINGS: MEDIA FILES & LARGE ASSETS
# Images/videos cannot be read by CLI tools — they only waste tokens
# =================================================================
*.jpg
*.jpeg
*.png
*.gif
*.ico
*.webp
*.mp4
*.webm
*.mp3
*.wav
*.pdf
*.zip
*.tar.gz

# =================================================================
# LOCAL DATABASE & LOGS
# =================================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.sqlite
*.db
# (Note: if you have a large JSON mock data file, add its name here)

# =================================================================
# IDE & OS CONFIGURATION
# =================================================================
.vscode/
.idea/
.DS_Store
Thumbs.db

.vercel
